# Public Ethereum RPC for ENS reads (no private key in the static bundle).
# Acceptable public defaults: https://ethereum-rpc.publicnode.com or https://eth.llamarpc.com
NEXT_PUBLIC_RPC_URL=https://ethereum-rpc.publicnode.com

# Deployed Cloudflare Worker WebSocket URL (set after `wrangler deploy`).
NEXT_PUBLIC_WS_URL=wss://billiard-worker.YOUR-SUBDOMAIN.workers.dev
